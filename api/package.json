{
  "name": "vendoriq-api",
  "version": "1.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev":         "nodemon index.js",
    "start":       "node index.js",
    "test":        "jest --runInBand",
    "test:watch":  "jest --watch",
    "lint":        "eslint . --ext .js",
    "setup":       "node scripts/setupIndexes.js",
    "seed":        "node scripts/seedLocalDBs.js",
    "seed:demo":   "node scripts/seedDemoAccount.js",
    "plans":       "node scripts/createRazorpayPlans.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "coverageDirectory": "coverage"
  },
  "dependencies": {
    "express":               "4.21.2",
    "mongoose":              "8.9.5",
    "bull":                  "4.16.4",
    "node-cron":             "3.0.3",
    "puppeteer":             "23.11.1",
    "exceljs":               "4.4.0",
    "nodemailer":            "6.9.16",
    "axios":                 "1.7.9",
    "zod":                   "3.24.1",
    "jsonwebtoken":          "9.0.2",
    "helmet":                "8.0.0",
    "express-rate-limit":    "7.5.0",
    "cors":                  "2.8.5",
    "dotenv":                "16.4.7",
    "winston":               "3.17.0",
    "@sentry/node":          "8.48.0",
    "nanoid":                "5.1.2",
    "papaparse":             "5.4.1",
    "socket.io":             "4.8.1",
    "razorpay":              "2.9.6",
    "sharp":                 "0.33.5",
    "cheerio":               "1.0.0",
    "fast-xml-parser":       "4.5.1",
    "scrapingbee":           "1.6.0",
    "ioredis":               "5.4.2",
    "@aws-sdk/client-s3":             "3.726.0",
    "@aws-sdk/s3-request-presigner":  "3.726.0",
    "multer":                "2.0.1",
    "csv-parse":             "5.6.0",
    "bcryptjs":              "2.4.3",
    "@sendgrid/mail":        "8.1.4",
    "passport":              "0.7.0",
    "passport-google-oauth20": "2.0.0"
  },
  "devDependencies": {
    "nodemon":       "3.1.9",
    "jest":          "29.7.0",
    "supertest":     "7.0.0",
    "@types/jest":   "29.5.14",
    "eslint":        "9.18.0"
  }
}
